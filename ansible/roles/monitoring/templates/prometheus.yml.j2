---
# Prometheus configuration

global:
  scrape_interval: {{ prometheus_scrape_interval }}
  evaluation_interval: {{ prometheus_evaluation_interval }}
  external_labels:
    environment: '{{ environment }}'
    cluster: 'pagasa-weather-demo'

# Alertmanager configuration
{% if alertmanager_enabled %}
alerting:
  alertmanagers:
    - static_configs:
        - targets:
            - alertmanager:9093
{% endif %}

# Load rules
rule_files:
  - 'alert_rules.yml'

# Scrape configurations
scrape_configs:
  # Prometheus itself
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  # Node Exporter - System metrics
  - job_name: 'node-exporter'
    static_configs:
      - targets: ['node-exporter:9100']
        labels:
          instance: '{{ ansible_hostname }}'

  # cAdvisor - Container metrics
  - job_name: 'cadvisor'
    static_configs:
      - targets: ['cadvisor:8080']
        labels:
          instance: '{{ ansible_hostname }}'

  # Backend API metrics (if implemented)
  - job_name: 'backend'
    metrics_path: '/metrics'
    static_configs:
      - targets: ['pagasa-backend:8000']
        labels:
          service: 'backend'
          environment: '{{ environment }}'

  # Docker daemon metrics
  - job_name: 'docker'
    static_configs:
      - targets: ['host.docker.internal:9323']
        labels:
          instance: '{{ ansible_hostname }}'

  # PostgreSQL exporter (optional - add if postgres_exporter is deployed)
  - job_name: 'postgres'
    static_configs:
      - targets: ['postgres-exporter:9187']
        labels:
          service: 'postgres'
          environment: '{{ environment }}'
    scrape_interval: 30s

  # Redis exporter (optional - add if redis_exporter is deployed)
  - job_name: 'redis'
    static_configs:
      - targets: ['redis-exporter:9121']
        labels:
          service: 'redis'
          environment: '{{ environment }}'
    scrape_interval: 30s
